# =============================================
# PREV-COR TPM - Environment Variables Template
# =============================================
# Copiază acest fișier în .env.local și completează valorile
# cp .env.example .env.local

# ========== DATABASE ==========
# Local SQLite (development)
DATABASE_URL="file:./prisma/dev.db"

# Turso (production) - https://turso.tech
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"

# ========== AUTHENTICATION ==========
# Generează: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Admin panel password
ADMIN_PASSWORD="your-admin-password"

# ========== EMAIL - SMTP ==========
# Gmail: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@your-domain.ro"
CONTACT_EMAIL="office@your-domain.ro"
ADMIN_EMAIL="admin@your-domain.ro"

# Email - Resend (alternativă la SMTP)
# RESEND_API_KEY="re_xxxxx"
# EMAIL_FROM="noreply@your-domain.ro"
# EMAIL_FROM_NAME="Your Company"

# ========== AI APIS ==========
# Google Gemini - https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# OpenAI GPT-4o (opțional) - https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-xxxxx"

# Anthropic Claude (recomandat pentru soluții tehnice) - https://console.anthropic.com/
# ANTHROPIC_API_KEY="sk-ant-xxxxx"

# Groq (fallback gratuit) - https://console.groq.com/
# GROQ_API_KEY="gsk_xxxxx"

# ========== STRIPE PAYMENTS ==========
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"

# ========== PUSH NOTIFICATIONS ==========
# Generează VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:office@your-domain.ro"

# ========== SENTRY ERROR TRACKING ==========
# https://sentry.io/
SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"

# ========== ANALYTICS ==========
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID="your-clarity-id"

# Google Search Console verification
GOOGLE_VERIFICATION_CODE="your-verification-code"

# ========== OAUTH (opțional) ==========
# Google OAuth - https://console.cloud.google.com/
# GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="xxxxx"

# Facebook OAuth - https://developers.facebook.com/
# FACEBOOK_CLIENT_ID="xxxxx"
# FACEBOOK_CLIENT_SECRET="xxxxx"

# ========== SECURITY ==========
# Backup encryption (min 32 chars)
BACKUP_ENCRYPTION_KEY="your-32-character-encryption-key"

# Security alerts email
SECURITY_ALERT_EMAIL="security@your-domain.ro"

# Cron job secret
CRON_SECRET="your-cron-secret"

# ========== SITE URLS ==========
NEXT_PUBLIC_SITE_URL="https://your-domain.ro"
NEXT_PUBLIC_BASE_URL="https://your-domain.ro"
