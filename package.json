{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "seed": "node seed-products.js",
    "stop": "powershell -Command \"Get-Process | Where-Object { $_.ProcessName -like 'node' } | Stop-Process -Force\"",
    "postinstall": "npx prisma generate && node scripts/fix-pdfkit-helvetica.js",
    "predev": "node scripts/sync-turso-schema.js --silent && node scripts/sync-suppliers.js --silent",
    "webhook": "node stripe-webhook-server.js",
    "db:backup": "node scripts/backup-database.js",
    "db:restore": "node scripts/restore-database.js && node scripts/sync-suppliers.js",
    "db:backup:turso": "node scripts/backup-turso-alert.js",
    "db:restore:turso": "node scripts/restore-turso.js",
    "db:sync-schema": "node scripts/sync-turso-schema.js",
    "db:sync-local": "node scripts/import-local-libsql.js",
    "db:sync-suppliers": "node scripts/sync-suppliers.js",
    "db:sync-suppliers:to-turso": "node scripts/sync-suppliers.js --to-turso",
    "db:import-products": "node scripts/import-products-excel.js",
    "prebuild": "node scripts/sync-turso-schema.js && node scripts/backup-turso-alert.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^6.19.0",
    "@prisma/client": "^6.19.2",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.3.0",
    "@sentry/nextjs": "^10.38.0",
    "@stripe/react-stripe-js": "^5.0.0",
    "@stripe/stripe-js": "^8.0.0",
    "@vercel/blob": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "chart.js": "^4.5.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "jspdf": "^4.0.0",
    "next": "^16.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.10",
    "otplib": "^13.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.17.2",
    "pdfreader": "^3.0.8",
    "prisma": "^6.18.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "recharts": "^3.2.1",
    "resend": "^6.9.2",
    "speakeasy": "^2.0.0",
    "stripe": "^19.3.1",
    "three": "^0.180.0",
    "unpdf": "^1.4.0",
    "web-push": "^3.6.7",
    "web-vitals": "^5.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/chart.js": "^2.9.41",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/next-auth": "^3.13.0",
    "@types/node": "^20.19.35",
    "@types/nodemailer": "^7.0.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@types/speakeasy": "^2.0.10",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "baseline-browser-mapping": "^2.9.17",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "next-auth": "^4.24.13",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.2",
    "playwright": "^1.58.2",
    "sql.js": "^1.14.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
